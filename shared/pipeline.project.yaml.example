# 轻量版项目绑定

project:
  name: my-project
  prd:
    primary: docs/prd.md

roots:
  project: .
  docs: lightweight-pipeline

knowledge:
  project_details: lightweight-pipeline/project-details.md

features:
  root: lightweight-pipeline/features

apps:
  backend:
    path: null
    dev:
      base_url:
  frontend:
    path: null
    dev:
      base_url:

bug_sources:
  - platform: meegle
    host_patterns:
      - meegle.example.com
    id_patterns:
      - "/work_item/([^/?#]+)"
      - "/issue/([^/?#]+)"
    mcp:
      server: Meegle
      required_tools:
        - get_workitem_detail
        - list_workitem_comments
